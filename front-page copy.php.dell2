<script>
    // Inisialisasi Swiper Slider
    const swiper = new Swiper('.hero-swiper', {
        loop: true,
        // Atur kecepatan transisi animasi di sini (contoh: 1000 = 1 detik)
        speed: 1000, 
        autoplay: { 
            // Atur durasi gambar diam di layar sebelum ganti (contoh: 3000 = 3 detik)
            delay: 3000, 
            disableOnInteraction: false 
        },
        pagination: { 
            el: '.swiper-pagination', 
            clickable: true 
        },
        effect: 'fade',
        fadeEffect: { crossFade: true }
    });
</script>

