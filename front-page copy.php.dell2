<style>
    /* Styling khusus Slider */
    .hero-swiper { width: 100%; height: 450px; position: relative; }
    .swiper-slide { background-position: center; background-size: cover; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 50px; }
    .swiper-pagination-bullet-active { background: #D74690 !important; }
    .swiper-pagination-bullet { background: #fff; opacity: 1; width: 12px; height: 12px; }
    
    /* Overlay agar teks/tombol tetap kontras */
    .slide-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, rgba(0,0,0,0) 60%, rgba(0,0,0,0.3) 100%); pointer-events: none; }
</style>

<main id="primary" class="site-main" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">

    <section class="hero-section" style="position: relative;">
        <div class="swiper hero-swiper">
            <div class="swiper-wrapper">
                <?php 
                // Mengumpulkan data dari 5 slot ACF
                $has_slides = false;
                for ($i = 1; $i <= 5; $i++) {
                    $img_url = get_field('hero_' . $i);
                    if ($img_url) : 
                        $has_slides = true;
                ?>
                    <div class="swiper-slide" style="background-image: url('<?php echo esc_url($img_url); ?>');">
                        <div class="slide-overlay"></div>
                    </div>
                <?php 
                    endif;
                } 
                
                // Fallback jika belum ada gambar yang diupload di ACF
                if (!$has_slides) : ?>
                    <div class="swiper-slide" style="background-color: #e0e0e0;">
                        <p style="color: #666;">Silakan upload gambar di ACF Field Beranda</p>
                    </div>
                <?php endif; ?>
            </div>
            
